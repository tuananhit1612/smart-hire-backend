# ==========================================
# SmartHire Docker Environment Configuration
# ==========================================
# Rename this file to `.env` before running:
# docker-compose up -d --build

# ------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------
DB_USER=postgres
DB_PASSWORD=your_secure_db_password
DB_NAME=smarthire

# ------------------------------------------
# Backend Application Settings
# ------------------------------------------
# Secret key for JWT generation (Use a long, random string)
JWT_SECRET=your_super_secret_jwt_key_here_make_it_at_least_32_chars

# The URL where your frontend is hosted (used for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:3000

# Optional: Google AI / Gemini API Key if your backend uses it
# GEMINI_API_KEY=your_gemini_api_key

# Optional: GitHub Client Secrets (if backend does token exchange)
# GITHUB_CLIENT_SECRET=your_github_client_secret

# ------------------------------------------
# Frontend Application Settings
# ------------------------------------------
# The URL pointing to your backend API
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# GitHub OAuth App Client ID
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id
